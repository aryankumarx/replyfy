# ========================================
# AI KEYBOARD ASSISTANT - ENVIRONMENT VARIABLES
# ========================================

# ===== CHOOSE ONE API (Use one, comment out the other) =====

# Option 1: FREE VERSION - Google Gemini (Recommended for initial stage!)
# Get your FREE API key: https://makersuite.google.com/app/apikey
# No credit card needed, 1500 requests/day FREE
GEMINI_API_KEY=your_gemini_api_key_here

# Option 2: PAID VERSION - Claude AI (Better quality, costs ~$0.05/user/month)
# Get API key: https://console.anthropic.com/
# quickstart.bat replaces the placeholder below with your key (line must stay uncommented for Claude)
ANTHROPIC_API_KEY=your_claude_api_key_here

# ===== SERVER CONFIGURATION =====
PORT=3000
NODE_ENV=development

# ===== SECURITY =====
# Generate a random string for JWT secret (change in production!)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ===== RATE LIMITING =====
# How many AI suggestions per day for free users
FREE_TIER_DAILY_LIMIT=20

# How many AI suggestions per day for Pro users
PRO_TIER_DAILY_LIMIT=1000

# ===== CORS (Allowed Origins) =====
# Add your frontend URLs here (comma-separated)
# For Android emulator, use http://10.0.2.2:8081
# For real device, use your computer's IP
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://10.0.2.2:8081

# ===== INSTRUCTIONS =====
# 1. Copy this file to .env: cp .env.example .env
# 2. Choose Gemini (FREE) or Claude (Paid)
# 3. Add your API key
# 4. NEVER commit .env to git (it's in .gitignore)

# ===== GEMINI (FREE) vs CLAUDE (PAID) =====
# Gemini FREE: 1500 requests/day, good quality, excellent at Hinglish
# Claude PAID: Unlimited, best quality, costs ~$50/month for 1000 users
# 
# Start with Gemini FREE, upgrade to Claude when making money!
